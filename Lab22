### Task1 (5.1) — Создание и приостановка потоков

```csharp
using System;
using System.Threading;

namespace Task1
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("=== Задание 5.1 ===");
            Console.WriteLine("Главный поток: печатает 0 (задержка 500мс)");
            Console.WriteLine("Второй поток: печатает 1 (задержка 1000мс)\n");

            Thread thread = new Thread(() =>
            {
                while (true)
                {
                    Console.Write("1 ");
                    Thread.Sleep(1000);
                }
            });
            thread.IsBackground = true;
            thread.Start();

            for (int i = 0; i < 20; i++)
            {
                Console.Write("0 ");
                Thread.Sleep(500);
            }

            Console.WriteLine("\n\nДемонстрация 5.1 завершена.");
            Console.WriteLine("Нажмите любую клавишу для выхода...");
            Console.ReadKey();
        }
    }
}
```

