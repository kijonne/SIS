### Task5 (5.5) — Отмена выполнения потоков

```csharp
using System;
using System.Threading;

namespace Task5
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("=== Задание 5.5 ===");
            Console.WriteLine("Имитация загрузки 10 файлов...\n");

            var cts = new CancellationTokenSource();
            Thread loader = new Thread(() => SimulateFileLoad(cts.Token));
            loader.Start();

            Console.WriteLine("Введите C и нажмите Enter — чтобы отменить");
            string input = Console.ReadLine()?.Trim().ToUpper();

            if (input == "C")
            {
                cts.Cancel();
                Console.WriteLine("Отмена отправлена...");
            }

            loader.Join();

            Console.WriteLine("\nЗадание 5.5 завершено.");
            Console.WriteLine("Нажмите любую клавишу для выхода...");
            Console.ReadKey();
        }

        private static void SimulateFileLoad(CancellationToken token)
        {
            try
            {
                for (int i = 1; i <= 10; i++)
                {
                    token.ThrowIfCancellationRequested();
                    Console.WriteLine($"Загрузка файла {i}/10...");
                    Thread.Sleep(1000);
                }
                Console.WriteLine("Загрузка завершена успешно!");
            }
            catch (OperationCanceledException)
            {
                Console.WriteLine("Загрузка отменена пользователем!");
            }
        }
    }
}
```

