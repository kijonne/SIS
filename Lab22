### Task4 (5.4) — Синхронизация потоков (с lock и без)

```csharp
using System;
using System.Threading;

namespace Task4
{
    class Program
    {
        private static int counter = 0;
        private static readonly object locker = new object();

        static void Main(string[] args)
        {
            Console.WriteLine("=== Задание 5.4 ===");

            // Без lock
            counter = 0;
            RunThreads(false);
            Console.WriteLine($"Результат БЕЗ lock: {counter}");

            // С lock
            counter = 0;
            RunThreads(true);
            Console.WriteLine($"Результат С lock: {counter} (должен быть 5000)");

            Console.WriteLine("\nЗадание 5.4 завершено.");
            Console.WriteLine("Нажмите любую клавишу для выхода...");
            Console.ReadKey();
        }

        private static void RunThreads(bool useLock)
        {
            Thread[] threads = new Thread[5];
            for (int i = 0; i < 5; i++)
            {
                threads[i] = new Thread(() => IncrementThread(useLock));
                threads[i].Start();
            }
            foreach (var t in threads) t.Join();
        }

        private static void IncrementThread(bool useLock)
        {
            for (int i = 0; i < 1000; i++)
            {
                if (useLock)
                {
                    lock (locker) counter++;
                }
                else
                {
                    counter++;
                }
                Thread.Sleep(1);
            }
        }
    }
}
```

