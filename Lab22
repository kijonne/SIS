### Task2 (5.2) — Обмен данными между потоками

```csharp
using System;
using System.Threading;

namespace Task2
{
    class Program
    {
        private static string commonVar = "";

        static void Main(string[] args)
        {
            Console.WriteLine("=== Задание 5.2 ===");

            Thread t = new Thread(MyThread);
            t.Start();

            for (int i = 0; i < 5; i++)
            {
                Console.WriteLine($"Главный поток: шаг {i + 1}");
                Thread.Sleep(1500);
            }

            commonVar = "x";
            Console.WriteLine("\nГлавный поток установил commonVar = \"x\"");
            t.Join();

            Console.WriteLine("Задание 5.2 завершено.");
            Console.WriteLine("Нажмите любую клавишу для выхода...");
            Console.ReadKey();
        }

        private static void MyThread()
        {
            while (commonVar != "x")
            {
                Console.WriteLine("Второй поток: выполняется...");
                Thread.Sleep(1000);
            }
            Console.WriteLine("Второй поток: получил сигнал остановки!");
        }
    }
}
```

