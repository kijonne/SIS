### Task3 (5.3) — Обмен данными через канал (один производитель — три потребителя)

```csharp
using System;
using System.Threading;
using System.Collections.Concurrent;

namespace Task3
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.WriteLine("=== Задание 5.3 ===");

            var channel = new BlockingCollection<int>(20);

            Thread producer = new Thread(() => Producer(channel));
            Thread c1 = new Thread(() => Consumer(channel, 1));
            Thread c2 = new Thread(() => Consumer(channel, 2));
            Thread c3 = new Thread(() => Consumer(channel, 3));

            producer.Start();
            c1.Start(); c2.Start(); c3.Start();

            producer.Join();
            c1.Join(); c2.Join(); c3.Join();

            Console.WriteLine("\nЗадание 5.3 завершено.");
            Console.WriteLine("Нажмите любую клавишу для выхода...");
            Console.ReadKey();
        }

        private static void Producer(BlockingCollection<int> channel)
        {
            for (int i = 1; i <= 20; i++)
            {
                channel.Add(i);
                Console.WriteLine($"Producer → добавил {i}");
                Thread.Sleep(300);
            }
            channel.CompleteAdding();
        }

        private static void Consumer(BlockingCollection<int> channel, int id)
        {
            foreach (var value in channel.GetConsumingEnumerable())
            {
                Console.WriteLine($"Consumer {id} ← обработал {value}");
                Thread.Sleep(100);
            }
        }
    }
}
```

