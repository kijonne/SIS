### 3. Передача и сжатие изображений (5.3)

**FileServer.csproj** (сервер сжимает изображение в 2 раза)

```csharp
using System;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Drawing.Imaging;
using System.IO;
using System.Net;
using System.Net.Sockets;
using System.Threading;

namespace FileServer
{
    class Program
    {
        private const int Port = 10000;

        static void Main(string[] args)
        {
            Console.WriteLine("=== ФАЙЛОВЫЙ СЕРВЕР (5.3.2) ===");
            TcpListener listener = new TcpListener(IPAddress.Any, Port);
            listener.Start();
            Console.WriteLine($"Сервер запущен на порту {Port}.");

            while (true)
            {
                TcpClient client = listener.AcceptTcpClient();
                Thread thread = new Thread(() => HandleClient(client));
                thread.Start();
            }
        }

        private static void HandleClient(TcpClient client)
        {
            try
            {
                NetworkStream stream = client.GetStream();

                // 5.3.2 — Читаем 8 байт размера файла
                byte[] sizeBytes = new byte[8];
                stream.ReadExactly(sizeBytes, 0, 8);
                long fileSize = BitConverter.ToInt64(sizeBytes, 0);

                // Читаем сами байты изображения
                byte[] imageBuffer = new byte[fileSize];
                stream.ReadExactly(imageBuffer, 0, (int)fileSize);

                Console.WriteLine($"Получено изображение размером {fileSize} байт. Сжимаем...");

                // Код сжатия из лабораторной (5.3.2)
                using var inputStream = new MemoryStream(imageBuffer);
                using var originalImage = new Bitmap(inputStream);

                int newWidth = originalImage.Width / 2;
                int newHeight = originalImage.Height / 2;

                using var resizedImage = new Bitmap(newWidth, newHeight);
                using (var graphics = Graphics.FromImage(resizedImage))
                {
                    graphics.InterpolationMode = InterpolationMode.HighQualityBicubic;
                    graphics.DrawImage(originalImage, 0, 0, newWidth, newHeight);
                }

                using var outputStream = new MemoryStream();
                resizedImage.Save(outputStream, ImageFormat.Jpeg);
                byte[] resizedBytes = outputStream.ToArray();

                // Отправляем обратно: 8 байт размера + байты
                byte[] resultSize = BitConverter.GetBytes((long)resizedBytes.Length);
                stream.Write(resultSize, 0, 8);
                stream.Write(resizedBytes, 0, resizedBytes.Length);

                Console.WriteLine($"Отправлен уменьшенный файл ({resizedBytes.Length} байт)");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка: {ex.Message}");
            }
            finally
            {
                client.Close();
            }
        }
    }
}
```

**FileClient.csproj** (клиент отправляет и получает изображение)

```csharp
using System;
using System.IO;
using System.Net.Sockets;

namespace FileClient
{
    class Program
    {
        private const string ServerIp = "127.0.0.1";
        private const int Port = 10000;

        static void Main(string[] args)
        {
            Console.WriteLine("=== КЛИЕНТ ДЛЯ ФАЙЛОВ (5.3.1) ===");
            Console.Write("Введите полный путь к изображению (jpg/png): ");
            string filePath = Console.ReadLine();

            if (!File.Exists(filePath))
            {
                Console.WriteLine("Файл не найден!");
                return;
            }

            byte[] imageBytes = File.ReadAllBytes(filePath);
            long fileSize = imageBytes.Length;

            TcpClient client = new TcpClient(ServerIp, Port);
            NetworkStream stream = client.GetStream();

            // 5.3.1 — Сначала 8 байт размера, потом байты
            byte[] sizeBytes = BitConverter.GetBytes(fileSize);
            stream.Write(sizeBytes, 0, 8);
            stream.Write(imageBytes, 0, imageBytes.Length);

            Console.WriteLine("Изображение отправлено. Ожидаем ответ от сервера...");

            // Читаем ответ от сервера
            byte[] resultSizeBytes = new byte[8];
            stream.ReadExactly(resultSizeBytes, 0, 8);
            long resultSize = BitConverter.ToInt64(resultSizeBytes, 0);

            byte[] resizedBytes = new byte[resultSize];
            stream.ReadExactly(resizedBytes, 0, (int)resultSize);

            // Сохраняем полученный уменьшенный файл
            string savedPath = "resized_" + Path.GetFileNameWithoutExtension(filePath) + ".jpg";
            File.WriteAllBytes(savedPath, resizedBytes);

            Console.WriteLine($"Готово! Уменьшенное изображение сохранено как: {savedPath}");
            client.Close();
        }
    }
}
```

**Как запускать 5.3:**  
1. Запусти **FileServer**.  
2. Запусти **FileClient**, укажи путь к картинке (например `C:\test.jpg`).  
Сервер сожмёт в 2 раза и вернёт — клиент сохранит файл `resized_test.jpg`.

