### 1. Простое клиент-серверное приложение (5.1)

**SimpleServer.csproj** (сервер отправляет сообщение каждые 5 секунд)

```csharp
using System;
using System.Net;
using System.Net.Sockets;
using System.Text;
using System.Threading;

namespace SimpleServer
{
    class Program
    {
        private const int Port = 8888;

        static void Main(string[] args)
        {
            Console.WriteLine("=== ПРОСТОЙ СЕРВЕР (5.1.2) ===");
            TcpListener listener = new TcpListener(IPAddress.Any, Port);
            listener.Start();
            Console.WriteLine($"Сервер запущен на порту {Port}. Ожидание клиента...");

            // 5.1.2 — Ожидаем подключение клиента
            TcpClient client = listener.AcceptTcpClient();
            Console.WriteLine("Клиент подключился!");

            NetworkStream stream = client.GetStream();

            while (true)
            {
                // Формируем сообщение
                string message = $"Привет от сервера! Текущее время: {DateTime.Now:HH:mm:ss}";
                byte[] data = Encoding.UTF8.GetBytes(message);

                try
                {
                    stream.Write(data, 0, data.Length);     // отправляем
                    Console.WriteLine($"Отправлено: {message}");
                }
                catch
                {
                    Console.WriteLine("Клиент отключился.");
                    break;
                }

                Thread.Sleep(5000); // 5 секунд (5.1.2)
            }

            listener.Stop();
        }
    }
}
```

**SimpleClient.csproj** (клиент читает данные из потока)

```csharp
using System;
using System.Net.Sockets;
using System.Text;

namespace SimpleClient
{
    class Program
    {
        private const string ServerIp = "127.0.0.1";
        private const int Port = 8888;

        static void Main(string[] args)
        {
            Console.WriteLine("=== ПРОСТОЙ КЛИЕНТ (5.1.1) ===");
            TcpClient client = new TcpClient(ServerIp, Port);
            Console.WriteLine("Подключились к серверу!");

            NetworkStream stream = client.GetStream();
            byte[] buffer = new byte[1024];

            while (true)
            {
                try
                {
                    int bytesRead = stream.Read(buffer, 0, buffer.Length);
                    if (bytesRead == 0) break;

                    string message = Encoding.UTF8.GetString(buffer, 0, bytesRead);
                    Console.WriteLine($"Получено от сервера: {message}");
                }
                catch
                {
                    Console.WriteLine("Соединение закрыто.");
                    break;
                }
            }

            client.Close();
        }
    }
}
```

**Как запускать 5.1:**  
1. Запусти **SimpleServer**.  
2. Запусти **SimpleClient**.  
Каждые 5 секунд в клиенте будет появляться сообщение.

### 2. Многопользовательское приложение (5.2)

**ConsoleServer.csproj** (сервер принимает нескольких клиентов)

```csharp
using System;
using System.Collections.Generic;
using System.Net;
using System.Net.Sockets;
using System.Text;
using System.Threading;

namespace ConsoleServer
{
    class Program
    {
        private const int Port = 9999;
        private static readonly List<TcpClient> clients = new List<TcpClient>();

        static void Main(string[] args)
        {
            Console.WriteLine("=== МНОГОПОЛЬЗОВАТЕЛЬСКИЙ СЕРВЕР (5.2.2) ===");
            TcpListener listener = new TcpListener(IPAddress.Any, Port);
            listener.Start();
            Console.WriteLine($"Сервер запущен на порту {Port}.");

            while (true)
            {
                TcpClient client = listener.AcceptTcpClient();
                clients.Add(client);
                Thread clientThread = new Thread(() => HandleClient(client));
                clientThread.Start();
            }
        }

        private static void HandleClient(TcpClient client)
        {
            string clientName = "Неизвестный";
            NetworkStream stream = client.GetStream();
            byte[] buffer = new byte[1024];

            try
            {
                // 5.2.1 — Сначала читаем имя пользователя
                int bytesRead = stream.Read(buffer, 0, buffer.Length);
                clientName = Encoding.UTF8.GetString(buffer, 0, bytesRead).Trim();

                Console.WriteLine($"Клиент подключился: {clientName}");

                while (true)
                {
                    bytesRead = stream.Read(buffer, 0, buffer.Length);
                    if (bytesRead == 0) break;

                    string text = Encoding.UTF8.GetString(buffer, 0, bytesRead).Trim();
                    string time = DateTime.Now.ToString("HH:mm:ss dd.MM.yyyy"); // формат по лабораторной

                    // 5.2.2 — Выводим на сервере: (Имя) чч:мм:сс дд.мм.гггг : текст
                    Console.WriteLine($"({clientName}) {time} : {text}");
                }
            }
            catch { }
            finally
            {
                client.Close();
                clients.Remove(client);
            }
        }
    }
}
```

**ConsoleClient.csproj** (клиент отправляет имя + текст)

```csharp
using System;
using System.Net.Sockets;
using System.Text;

namespace ConsoleClient
{
    class Program
    {
        private const string ServerIp = "127.0.0.1";
        private const int Port = 9999;

        static void Main(string[] args)
        {
            Console.WriteLine("=== КЛИЕНТ (5.2.1) ===");
            TcpClient client = new TcpClient(ServerIp, Port);
            NetworkStream stream = client.GetStream();

            Console.Write("Введите ваше имя: ");
            string name = Console.ReadLine() ?? "Аноним";
            byte[] nameData = Encoding.UTF8.GetBytes(name);
            stream.Write(nameData, 0, nameData.Length);   // отправляем имя один раз

            Console.WriteLine("Введите текст (пустая строка — выход):");

            while (true)
            {
                string text = Console.ReadLine();
                if (string.IsNullOrEmpty(text)) break;

                byte[] data = Encoding.UTF8.GetBytes(text);
                stream.Write(data, 0, data.Length);
            }

            client.Close();
        }
    }
}
```

