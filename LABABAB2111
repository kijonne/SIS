            rtbMotherboard.Clear();
            rtbMotherboard.AppendText("Загрузка материнской платы...\n\n");
            try
            {
                var searcher = new ManagementObjectSearcher("SELECT * FROM Win32_MotherboardDevice");
                int i = 1;
                foreach (ManagementObject obj in searcher.Get())
                {
                    rtbMotherboard.AppendText($"Материнская плата {i}:\nПроизводитель: {obj["Manufacturer"] ?? "N/A"}\nМодель: {obj["Product"] ?? "N/A"}\nВерсия: {obj["Version"] ?? "N/A"}\n\n");
