        private void LoadNetwork()
        {
            if (rtbNetwork == null) return;
            rtbNetwork.Clear();
            rtbNetwork.AppendText("Загрузка сети...\n\n");
            try
            {
                foreach (NetworkInterface nic in NetworkInterface.GetAllNetworkInterfaces())
                {
                    rtbNetwork.AppendText($"Имя: {nic.Name}\nОписание: {nic.Description}\nТип: {nic.NetworkInterfaceType}\nСтатус: {nic.OperationalStatus}\nСкорость: {nic.Speed / 1_000_000} Мбит/с\n\n");
                }
            }
            catch (Exception ex) { rtbNetwork.AppendText($"ОШИБКА: {ex.Message}"); }
        }

        private void LoadInstalledPrograms()
        {
            if (lbPrograms == null) return;
            lbPrograms.Items.Clear();
            var programs = new List<string>();

            string[] paths = 
            {
                @"Software\Microsoft\Windows\CurrentVersion\Uninstall",
                @"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall",
                @"SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall"
            };

            try
            {
                foreach (string path in paths)
                {
                    using (var key = Registry.CurrentUser.OpenSubKey(path))
                        if (key != null) AddProgramsFromKey(key, programs);

                    using (var key = Registry.LocalMachine.OpenSubKey(path))
                        if (key != null) AddProgramsFromKey(key, programs);
                }

                foreach (var p in programs.Distinct().OrderBy(x => x))
                    lbPrograms.Items.Add(p);

                if (lbPrograms.Items.Count == 0)
                    lbPrograms.Items.Add("Программы не найдены");
            }
            catch (Exception ex)
            {
                lbPrograms.Items.Add($"ОШИБКА: {ex.Message}");
            }
        }

        private void AddProgramsFromKey(RegistryKey key, List<string> list)
        {
            foreach (string subKeyName in key.GetSubKeyNames())
            {
                using (var subKey = key.OpenSubKey(subKeyName))
                {
                    string name = subKey?.GetValue("DisplayName") as string;
                    if (!string.IsNullOrEmpty(name))
                        list.Add(name);
                }
            }
        }
    }
