            {
                var searcher = new ManagementObjectSearcher("SELECT * FROM Win32_Processor");
                int i = 1;
                foreach (ManagementObject obj in searcher.Get())
                {
                    rtbProcessor.AppendText($"Процессор {i}:\nНазвание: {obj["Name"] ?? "N/A"}\nПроизводитель: {obj["Manufacturer"] ?? "N/A"}\nМакс. частота: {obj["MaxClockSpeed"] ?? "N/A"} MHz\nЯдер: {obj["NumberOfCores"] ?? "N/A"}\n\n");
