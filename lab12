2 Кнопка — время + счётчик нажатий в Serial
Подключение: только кнопка на пин 2.
C++const int button = 2;

unsigned long startTime = 0;
int count = 0;
bool last = HIGH;

void setup() {
  pinMode(button, INPUT_PULLUP);
  Serial.begin(9600);
  startTime = millis();
}

void loop() {
  bool now = digitalRead(button);
  if (now == LOW && last == HIGH) {          // нажатие
    count++;
    Serial.print("Время: ");
    Serial.print((millis() - startTime)/1000);
    Serial.print(" сек | Нажатий: ");
    Serial.println(count);
  }
  last = now;
  delay(50);   // антидребезг
}


