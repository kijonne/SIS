const int button = 2;
const int led = 9;

volatile bool fast = true;
unsigned long pressTime = 0;

void setup() {
  pinMode(button, INPUT_PULLUP);
  pinMode(led, OUTPUT);
  attachInterrupt(digitalPinToInterrupt(button), isr, CHANGE);
}

void loop() {
  int speed = fast ? 150 : 600;               // период мигания
  static unsigned long last = 0;
  if (millis() - last >= speed) {
    last = millis();
    digitalWrite(led, !digitalRead(led));
  }
}

void isr() {
  if (digitalRead(button) == LOW) pressTime = millis();
  else if (millis() - pressTime >= 3000) fast = !fast;
}
