const int button = 2;
const int red = 9;
const int green = 10;

volatile bool cross = false;

void setup() {
  pinMode(button, INPUT_PULLUP);
  pinMode(red, OUTPUT);
  pinMode(green, OUTPUT);
  attachInterrupt(digitalPinToInterrupt(button), press, FALLING);
  digitalWrite(red, HIGH);
}

void loop() {
  if (cross) {
    cross = false;
    delay(3000);                     // ждём 3 сек
    for (int i = 0; i < 3; i++) {    // мигаем 3 раза
      digitalWrite(green, HIGH); delay(250);
      digitalWrite(green, LOW);  delay(250);
    }
    digitalWrite(green, HIGH);       // зелёный 10 сек
    delay(10000);
    digitalWrite(green, LOW);
    digitalWrite(red, HIGH);         // обратно красный
  }
}

void press() {
  cross = true;
}




