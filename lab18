using System.IO;
using System.Windows;

namespace LabWork17
{
    public partial class DiskPropertiesWindow : Window
    {
        public DiskPropertiesWindow(string drivePath)
        {
            InitializeComponent();
            LoadInfo(drivePath);
        }

        private void LoadInfo(string drivePath)
        {
            var drive = new DriveInfo(drivePath);

            tbDrive.Text = drive.Name;
            tbLabel.Text = drive.VolumeLabel ?? "Нет метки";
            tbType.Text = drive.DriveType.ToString();
            tbFS.Text = drive.DriveFormat ?? "—";

            long total = drive.TotalSize;
            long free = drive.TotalFreeSpace;
            long used = total - free;

            tbTotal.Text = MainWindow.FormatFileSize(total);
            tbUsed.Text = MainWindow.FormatFileSize(used);
            tbFree.Text = MainWindow.FormatFileSize(free);

            double percent = total > 0 ? (double)used / total * 100 : 0;
            pbUsed.Value = percent;
            tbPercent.Text = $"{percent:0.##}% занято";
        }
    }
}
