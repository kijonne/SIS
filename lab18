```csharp
using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Windows;

namespace LabWork17
{
    public partial class FolderPropertiesWindow : Window
    {
        public FolderPropertiesWindow(string folderPath)
        {
            InitializeComponent();
            LoadFolderInfo(folderPath);
        }

        private void LoadFolderInfo(string path)
        {
            var dir = new DirectoryInfo(path);
            tbName.Text = dir.Name;

            var stats = GetFolderStats(path);
            tbFiles.Text = stats.FileCount.ToString();
            tbFolders.Text = stats.DirCount.ToString();
            tbSize.Text = MainWindow.FormatFileSize(stats.TotalSize);

            var drive = new DriveInfo(Path.GetPathRoot(path));
            double percent = drive.TotalSize > 0 ? (double)stats.TotalSize / drive.TotalSize * 100 : 0;
            pbPercent.Value = percent;
            tbPercentText.Text = $"{percent:0.##}%";

            lvTopFiles.ItemsSource = GetTop5Files(path);
        }

        private (long TotalSize, int FileCount, int DirCount) GetFolderStats(string path)
        {
            long size = 0;
            int files = 0;
            int dirs = 1; // сама папка

            try
            {
                foreach (var f in Directory.EnumerateFiles(path, "*.*", SearchOption.AllDirectories))
                {
                    size += new FileInfo(f).Length;
                    files++;
                }
                dirs += Directory.EnumerateDirectories(path, "*.*", SearchOption.AllDirectories).Count();
            }
            catch { }

            return (size, files, dirs);
        }

        private List<TopFileItem> GetTop5Files(string path)
        {
            var files = new List<(string Path, long Size)>();

            try
            {
                foreach (var f in Directory.EnumerateFiles(path, "*.*", SearchOption.AllDirectories))
                {
                    var fi = new FileInfo(f);
                    files.Add((fi.FullName, fi.Length));
                }
            }
            catch { }

            return files.OrderByDescending(x => x.Size)
                        .Take(5)
                        .Select(x => new TopFileItem
                        {
                            SizeStr = MainWindow.FormatFileSize(x.Size),
                            FullPath = x.Path
                        })
                        .ToList();
        }
    }
}
