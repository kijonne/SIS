```csharp
using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;
using System.Windows.Media.Imaging;

namespace LabWork17
{
    public partial class MainWindow : Window
    {
        private string currentPath;
        private readonly string defaultPath = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        private const string DrivesRoot = "";

        private BitmapImage fileCopy, fileOpen, folder, fileVideo;

        private bool isDrivesView = false;
        private GridView filesGridView;

        public MainWindow()
        {
            InitializeComponent();
        }

        private void Window_Loaded(object sender, RoutedEventArgs e)
        {
            fileCopy = new BitmapImage(new Uri("/Images/fileCopy.png", UriKind.Relative));
            fileOpen = new BitmapImage(new Uri("/Images/fileOpen.png", UriKind.Relative));
            folder = new BitmapImage(new Uri("/Images/folder.png", UriKind.Relative));
            fileVideo = new BitmapImage(new Uri("/Images/fileVideo.png", UriKind.Relative));

            filesGridView = lvFiles.View as GridView;   // сохраняем оригинальные колонки

            // Запуск — сразу показываем список дисков (аналог «Мой компьютер»)
            currentPath = DrivesRoot;
            txtPath.Text = "";
            LoadDrives();
        }

        // ====================== ВИД ДИСКОВ ======================
        private void LoadDrives()
        {
            isDrivesView = true;
            currentPath = DrivesRoot;
            txtPath.Text = "";

            var items = new List<FileItem>();

            foreach (var drive in DriveInfo.GetDrives())
            {
                if (!drive.IsReady) continue;

                long total = drive.TotalSize;
                long free = drive.TotalFreeSpace;
                double percent = total > 0 ? (double)(total - free) / total * 100 : 0;

                string label = string.IsNullOrEmpty(drive.VolumeLabel) ? "Локальный диск" : drive.VolumeLabel;
                string name = $"{drive.Name.TrimEnd('\\')} ({label})";

                items.Add(new FileItem
                {
                    Image = folder,
                    Name = name,
                    FullPath = drive.Name,
                    IsDirectory = true,
                    IsDrive = true,
                    TotalSize = total,
                    FreeSpace = free,
                    UsedPercent = percent,
                    TotalSizeStr = FormatFileSize(total),
                    FreeSpaceStr = FormatFileSize(free)
                });
            }

            lvFiles.ItemsSource = items.OrderBy(i => i.Name);
            SetDrivesView();
        }

        private void SetDrivesView()
        {
            var gv = new GridView();

            // Иконка
            var iconCol = new GridViewColumn { Header = "", Width = 30 };
            var iconFactory = new FrameworkElementFactory(typeof(Image));
            iconFactory.SetValue(Image.SourceProperty, new System.Windows.Data.Binding("Image"));
            iconFactory.SetValue(Image.WidthProperty, 24.0);
            iconFactory.SetValue(Image.HeightProperty, 24.0);
            iconCol.CellTemplate = new DataTemplate { VisualTree = iconFactory };
            gv.Columns.Add(iconCol);

            // Буква и метка тома
            gv.Columns.Add(new GridViewColumn 
            { 
                Header = "Буква и метка тома", 
                Width = 300, 
                DisplayMemberBinding = new System.Windows.Data.Binding("Name") 
            });

            // Общий размер
            gv.Columns.Add(new GridViewColumn 
            { 
                Header = "Общий размер", 
                Width = 120, 
                DisplayMemberBinding = new System.Windows.Data.Binding("TotalSizeStr") 
            });

            // Свободно
            gv.Columns.Add(new GridViewColumn 
            { 
                Header = "Свободно", 
                Width = 120, 
                DisplayMemberBinding = new System.Windows.Data.Binding("FreeSpaceStr") 
            });

            // ProgressBar % занято
            var progCol = new GridViewColumn { Header = "% занято", Width = 180 };
            var progFactory = new FrameworkElementFactory(typeof(ProgressBar));
            progFactory.SetValue(ProgressBar.ValueProperty, new System.Windows.Data.Binding("UsedPercent"));
            progFactory.SetValue(ProgressBar.MinimumProperty, 0.0);
            progFactory.SetValue(ProgressBar.MaximumProperty, 100.0);
            progFactory.SetValue(ProgressBar.HeightProperty, 18.0);
            progCol.CellTemplate = new DataTemplate { VisualTree = progFactory };
            gv.Columns.Add(progCol);

            lvFiles.View = gv;
        }

        // ====================== ОБЫЧНЫЙ ВИД ПАПОК ======================
        private void LoadDirectory(string path)
        {
            if (string.IsNullOrEmpty(path))
            {
                LoadDrives();
                return;
            }

            isDrivesView = false;

            try
            {
                if (!Directory.Exists(path))
                {
                    MessageBox.Show("Указанный вами каталог не существует", "Ошибка", MessageBoxButton.OK, MessageBoxImage.Error);
                    return;
                }

                currentPath = path;
                txtPath.Text = path;

                var items = new List<FileItem>();

                if (Directory.GetParent(path) != null)
                {
                    items.Add(new FileItem
                    {
                        Name = "..",
                        FullPath = Directory.GetParent(path).FullName,
                        IsDirectory = true
                    });
                }

                foreach (var dir in Directory.GetDirectories(path))
                {
                    var di = new DirectoryInfo(dir);
                    items.Add(new FileItem
                    {
                        Image = folder,
                        Name = di.Name,
                        FullPath = di.FullName,
                        LastWriteTime = di.LastWriteTime,
                        Size = "",
                        IsDirectory = true,
                        IsDrive = false
                    });
                }

                foreach (var file in Directory.GetFiles(path))
                {
                    var fi = new FileInfo(file);
                    items.Add(new FileItem
                    {
                        Image = GetIconForFile(fi),
                        Name = fi.Name,
                        FullPath = fi.FullName,
                        LastWriteTime = fi.LastWriteTime,
                        Size = FormatFileSize(fi.Length),
                        IsDirectory = false
                    });
                }

                lvFiles.ItemsSource = items.OrderBy(i => !i.IsDirectory).ThenBy(i => i.Name);
                lvFiles.View = filesGridView;   // возвращаем обычные колонки
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка загрузки каталога:\n{ex.Message}", "Ошибка", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private BitmapImage GetIconForFile(FileInfo fi)
        {
            string ext = fi.Extension.ToLower();
            if (ext == ".png" || ext == ".jpg" || ext == ".jpeg" || ext == ".gif" || ext == ".bmp")
                return fileVideo;
            return fileOpen;
        }

        public static string FormatFileSize(long bytes)
        {
            if (bytes == 0) return "0 Б";
            string[] sizes = { "Б", "КБ", "МБ", "ГБ" };
            int order = 0;
            double size = bytes;
            while (size >= 1024 && order < sizes.Length - 1)
            {
                order++;
                size /= 1024;
            }
            return $"{size:0.##} {sizes[order]}";
        }

        // ====================== ПЕРЕХОДЫ ======================
        private void MyComputer_Click(object sender, RoutedEventArgs e)
        {
            LoadDrives();
        }

        // ====================== СВОЙСТВА (контекстное меню) ======================
        private void CtxProperties_Click(object sender, RoutedEventArgs e)
        {
            if (lvFiles.SelectedItem is not FileItem item) return;

            if (item.IsDrive)
            {
                new DiskPropertiesWindow(item.FullPath).ShowDialog();
            }
            else if (item.IsDirectory && item.Name != "..")
            {
                new FolderPropertiesWindow(item.FullPath).ShowDialog();
            }
        }

        // ====================== ДВОЙНОЙ КЛИК (оставлен как был) ======================
        private void LvFiles_MouseDoubleClick(object sender, MouseButtonEventArgs e)
        {
            if (lvFiles.SelectedItem is FileItem item)
            {
                if (item.IsDirectory)
                {
                    LoadDirectory(item.FullPath);
                }
                else
                {
                    try
                    {
                        Process.Start(new ProcessStartInfo
                        {
                            FileName = item.FullPath,
                            UseShellExecute = true
                        });
                    }
                    catch (Exception ex)
                    {
                        MessageBox.Show($"Не удалось открыть файл:\n{ex.Message}");
                    }
                }
            }
        }

        // ====================== ОСТАЛЬНЫЕ ОБРАБОТЧИКИ (копирование, выход и т.д.) ======================
        // Они у тебя уже были — оставь как есть
        private void Exit_Click(object sender, RoutedEventArgs e) => Close();
        // BtnGo_Click, TxtPath_KeyDown, CtxCopy_Click и т.д. — оставь без изменений
    }
}
