// ЗАДАНИЕ 5.5 — Terminal.Gui: TUI-интерфейс авторизации
// ─────────────────────────────────────────────────────────────
static void RunTui()
{
    Application.Init();

    var top = Application.Top;

    // Главное окно
    var win = new Window("Авторизация")
    {
        X = Pos.Center(),
        Y = Pos.Center(),
        Width  = 50,
        Height = 12,
    };
    top.Add(win);

    // Поле ввода логина
    var lblLogin = new Label("Логин:  ") { X = 2, Y = 2 };
    var txtLogin = new TextField("")    { X = 12, Y = 2, Width = 30 };

    // Поле ввода пароля (5.5.3 — поле для пароля)
    var lblPwd = new Label("Пароль: ") { X = 2, Y = 4 };
    var txtPwd  = new TextField("")    { X = 12, Y = 4, Width = 30, Secret = true };

    // Кнопка «Войти»
    var btnLogin = new Button("Войти") { X = Pos.Center(), Y = 7 };

    // 5.5.3 — обработчик кнопки: проверяем данные, выводим диалог
    btnLogin.Clicked += () =>
    {
        var users    = LoadUsers();
        string login = txtLogin.Text.ToString() ?? "";
        string pwd   = txtPwd.Text.ToString()   ?? "";

        string message = (users.TryGetValue(login, out var stored) && stored == pwd)
            ? $"✓ Добро пожаловать, {login}!"
            : "✗ Неверный логин или пароль.";

        // 5.5.3 — диалоговое окно для результата
        MessageBox.Query("Результат", message, "OK");
    };

    win.Add(lblLogin, txtLogin, lblPwd, txtPwd, btnLogin);

    Application.Run();
    Application.Shutdown();
}

// ─────────────────────────────────────────────────────────────
// ТОЧКА ВХОДА — System.CommandLine (5.1, 5.2, 5.3, 5.5)
// ─────────────────────────────────────────────────────────────

// ── 5.3.1 — Общие параметры --login и --pwd ──────────────────
var loginOption = new Option<string?>("--login", "Логин пользователя");
var pwdOption   = new Option<string?>("--pwd",   "Пароль пользователя");

// ── 5.5.1 — Параметр --ui ────────────────────────────────────
var uiOption = new Option<bool>("--ui", "Запустить графический TUI-интерфейс");

// ── Корневая команда (5.1) ────────────────────────────────────
var rootCommand = new RootCommand("Утилита авторизации пользователей");
rootCommand.AddOption(loginOption);
rootCommand.AddOption(pwdOption);
rootCommand.AddOption(uiOption);

rootCommand.SetHandler((string? login, string? pwd, bool ui) =>
{
    if (ui)
    {
        RunTui();          // 5.5 — TUI-режим
        return;
    }
    LoginInteractive(login, pwd);  // 5.1 / 5.3 — CLI-режим
},
loginOption, pwdOption, uiOption);

// ── 5.2 — Подкоманда register ────────────────────────────────
var registerCommand = new Command("register", "Регистрация нового пользователя");
registerCommand.AddOption(loginOption);
registerCommand.AddOption(pwdOption);

registerCommand.SetHandler((string? login, string? pwd) =>
{
    RegisterInteractive(login, pwd);   // 5.2 / 5.3
},
loginOption, pwdOption);

rootCommand.AddCommand(registerCommand);

// Запуск
return await rootCommand.InvokeAsync(args);
