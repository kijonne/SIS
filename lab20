                        </GridView>
                    </ListView.View>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Снять задачу" Click="KillProcess_Click"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                </ListView>
            </TabItem>

            <!-- Вкладка "Приложения" -->
            <TabItem Header="Приложения">
                <ListView x:Name="lvApplications" Margin="10">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Приложение" Width="400" DisplayMemberBinding="{Binding AppName}"/>
                            <GridViewColumn Header="Время запуска" Width="220" DisplayMemberBinding="{Binding StartTime}"/>
                        </GridView>
                    </ListView.View>
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Снять задачу" Click="KillProcess_Click"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                </ListView>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
```

#### 2. MainWindow.xaml.cs — логика главного окна

```csharp
using System;
using System.Diagnostics;
using System.Linq;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Threading;

namespace ProcessMonitor
{
    public partial class MainWindow : Window
    {
        private DispatcherTimer updateTimer;

        public MainWindow()
        {
            InitializeComponent();
            SetupTimer();
            UpdateAllData();                    // первое обновление при запуске
        }

        // Настраиваем таймер для автоматического обновления каждые 3 секунды
        private void SetupTimer()
        {
            updateTimer = new DispatcherTimer();
            updateTimer.Interval = TimeSpan.FromSeconds(3);
            updateTimer.Tick += (s, e) => UpdateAllData();
            updateTimer.Start();
        }

        // Обновляем обе вкладки
        private void UpdateAllData()
        {
            UpdateProcessesList();
            UpdateApplicationsList();
        }

        // ====================== ПРОЦЕССЫ ======================
        private void UpdateProcessesList()
        {
            var processes = Process.GetProcesses()
                .Select(p => new
                {
                    ProcessName = p.ProcessName,
                    Id = p.Id,
                    MemoryMB = Math.Round(p.WorkingSet64 / (1024.0 * 1024), 2)
                })
                .OrderBy(p => p.ProcessName)
                .ToList();

            lvProcesses.ItemsSource = processes;
            tbStatus.Text = $"Запущенных процессов: {processes.Count}";
        }

        // ====================== ПРИЛОЖЕНИЯ ======================
        private void UpdateApplicationsList()
        {
            var apps = Process.GetProcesses()
                .Where(p => !string.IsNullOrWhiteSpace(p.MainWindowTitle))
                .Select(p => new
                {
                    AppName = p.MainWindowTitle,
                    StartTime = p.StartTime.ToString("dd.MM.yyyy HH:mm:ss")
                })
                .OrderBy(a => a.AppName)
                .ToList();

            lvApplications.ItemsSource = apps;
        }

        // Снятие задачи (работает и для процессов, и для приложений)
        private void KillProcess_Click(object sender, RoutedEventArgs e)
        {
            ListView currentList = tabControl.SelectedIndex == 0 ? lvProcesses : lvApplications;

            if (currentList.SelectedItem == null)
            {
                MessageBox.Show("Выберите процесс или приложение для завершения.", "Внимание");
                return;
            }

            try
            {
                dynamic selected = currentList.SelectedItem;
                int pid = tabControl.SelectedIndex == 0 ? selected.Id : GetPidByWindowTitle(selected.AppName);

                if (pid == 0) return;

                Process process = Process.GetProcessById(pid);
                process.Kill();
                process.WaitForExit(1500);

                UpdateAllData();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Не удалось завершить процесс:\n{ex.Message}", "Ошибка", 
                               MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private int GetPidByWindowTitle(string title)
        {
            var proc = Process.GetProcesses().FirstOrDefault(p => p.MainWindowTitle == title);
            return proc?.Id ?? 0;
        }

        // ====================== МЕНЮ ======================
        private void MenuStartNew_Click(object sender, RoutedEventArgs e)
        {
            var startWindow = new StartProcessWindow();
            if (startWindow.ShowDialog() == true)
            {
                UpdateAllData();
            }
        }

        private void MenuExit_Click(object sender, RoutedEventArgs e)
        {
            Application.Current.Shutdown();
        }
    }
}
```

#### 3. Окно запуска новой задачи — StartProcessWindow.xaml

```xml
<Window x:Class="ProcessMonitor.StartProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запустить новую задачу" Height="180" Width="500" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Укажите путь к исполняемому файлу (.exe):" Margin="0,0,0,8" FontWeight="Bold"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,15">
            <Button Content="Обзор..." Width="90" Click="Browse_Click" DockPanel.Dock="Right"/>
            <TextBox x:Name="tbPath" Margin="0,0,10,0" Height="25"/>
        </DockPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="90" Margin="5" Click="Ok_Click"/>
            <Button Content="Отмена" Width="90" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
```

#### 4. StartProcessWindow.xaml.cs

```csharp
using Microsoft.Win32;
using System;
using System.Diagnostics;
using System.Windows;

namespace ProcessMonitor
{
    public partial class StartProcessWindow : Window
    {
        public StartProcessWindow()
        {
            InitializeComponent();
        }

        private void Browse_Click(object sender, RoutedEventArgs e)
        {
            OpenFileDialog dlg = new OpenFileDialog
            {
                Filter = "Приложения (*.exe)|*.exe|Все файлы (*.*)|*.*",
                Title = "Выберите программу для запуска"
            };

            if (dlg.ShowDialog() == true)
            {
                tbPath.Text = dlg.FileName;
            }
        }

        private void Ok_Click(object sender, RoutedEventArgs e)
        {
            if (string.IsNullOrWhiteSpace(tbPath.Text))
            {
                MessageBox.Show("Введите или выберите путь к файлу!", "Ошибка");
                return;
            }

            try
            {
                Process.Start(new ProcessStartInfo(tbPath.Text) { UseShellExecute = true });
                DialogResult = true;
                Close();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Ошибка запуска:\n{ex.Message}", "Ошибка");
            }
        }

        private void Cancel_Click(object sender, RoutedEventArgs e)
        {
            DialogResult = false;
            Close();
        }
    }
}
```

