        </StatusBar>

        <!-- TabControl занимает почти всё пространство -->
        <TabControl Margin="0,25,0,25" x:Name="tabControl">

            <!-- Вкладка "Процессы" -->
            <TabItem Header="Процессы">
                <ListView x:Name="lvProcesses" Margin="10">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Имя процесса" Width="280" DisplayMemberBinding="{Binding ProcessName}"/>
