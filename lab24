**Готово!** Теперь вся лабораторная работа №24 сделана **на WPF** (Windows Presentation Foundation).  
Проект называется **LabWork24** — одно решение, три отдельных окна (по одному на каждое задание 5.1–5.3).  
Ничего лишнего, строго по требованиям лабораторной.

### Как создать проект в WPF

1. Запустите **Visual Studio**.
2. **File → New → Project**
3. Выберите **WPF App** (или WPF Application .NET Framework / .NET 8 — не важно).
4. Название проекта: **`LabWork24`** → **Create**.
5. Удалите файл `MainWindow.xaml` (он нам не нужен).

6. Добавьте три новых окна:  
   - **Project → Add Window** → `EmptyScreenWindow.xaml`  
   - **Project → Add Window** → `PhotoScreenWindow.xaml`  
   - **Project → Add Window** → `ClockScreenWindow.xaml`

### 1. Заставка «Пустой экран» (5.1) — EmptyScreenWindow.xaml

**XAML** (полностью замените содержимое):

```xml
<Window x:Class="LabWork24.EmptyScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EmptyScreen" Height="450" Width="800"
        WindowStyle="None" WindowState="Maximized"
        Background="Black"
        KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove"
        Loaded="Window_Loaded">
</Window>
```

**Code-behind** (`EmptyScreenWindow.xaml.cs`) — полностью замените:

```csharp
using System;
using System.Windows;
using System.Windows.Input;

namespace LabWork24
{
    public partial class EmptyScreenWindow : Window
    {
        private Point lastMousePosition;

        public EmptyScreenWindow()
        {
            InitializeComponent();
        }

        private void Window_Loaded(object sender, RoutedEventArgs e)
        {
            lastMousePosition = Mouse.GetPosition(this);
        }

        private void Window_KeyDown(object sender, KeyEventArgs e)
        {
            this.Close();
        }

        private void Window_MouseMove(object sender, MouseEventArgs e)
        {
            Point current = Mouse.GetPosition(this);
            if (Math.Abs(current.X - lastMousePosition.X) > 3 ||
                Math.Abs(current.Y - lastMousePosition.Y) > 3)
            {
                this.Close();
            }
            lastMousePosition = current;
        }
    }
}
```

### 2. Заставка «Фотографии» (5.2) — PhotoScreenWindow.xaml

**XAML**:

```xml
<Window x:Class="LabWork24.PhotoScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhotoScreen" Height="450" Width="800"
        WindowStyle="None" WindowState="Maximized"
        Background="Black"
        KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove"
        Loaded="Window_Loaded">
    <Grid>
        <Image x:Name="photoImage" Stretch="Uniform" />
    </Grid>
</Window>
```

**Code-behind** (`PhotoScreenWindow.xaml.cs`):

```csharp
using System;
using System.IO;
using System.Windows;
using System.Windows.Input;
using System.Windows.Media.Imaging;
using System.Windows.Threading;

namespace LabWork24
{
    public partial class PhotoScreenWindow : Window
    {
        private string[] images;
        private int currentIndex = 0;
        private Point lastMousePosition;
        private DispatcherTimer timer;

        public PhotoScreenWindow()
        {
            InitializeComponent();
        }

        private void Window_Loaded(object sender, RoutedEventArgs e)
        {
            string picturesPath = Environment.GetFolderPath(Environment.SpecialFolder.MyPictures);
            var fileList = new System.Collections.Generic.List<string>();

            foreach (string file in Directory.GetFiles(picturesPath))
            {
                string ext = Path.GetExtension(file).ToLower();
                if (ext == ".jpg" || ext == ".jpeg" || ext == ".png" || ext == ".bmp" || ext == ".gif")
                    fileList.Add(file);
            }

            images = fileList.ToArray();

            if (images.Length == 0)
            {
                MessageBox.Show("В папке «Изображения» нет картинок!");
                this.Close();
                return;
            }

            photoImage.Source = new BitmapImage(new Uri(images[0]));

            timer = new DispatcherTimer();
            timer.Interval = TimeSpan.FromSeconds(10);
            timer.Tick += Timer_Tick;
            timer.Start();

            lastMousePosition = Mouse.GetPosition(this);
        }

        private void Timer_Tick(object sender, EventArgs e)
        {
            currentIndex = (currentIndex + 1) % images.Length;
            photoImage.Source = new BitmapImage(new Uri(images[currentIndex]));
        }

        private void Window_KeyDown(object sender, KeyEventArgs e)
        {
            this.Close();
        }

        private void Window_MouseMove(object sender, MouseEventArgs e)
        {
            Point current = Mouse.GetPosition(this);
            if (Math.Abs(current.X - lastMousePosition.X) > 3 ||
                Math.Abs(current.Y - lastMousePosition.Y) > 3)
            {
                this.Close();
            }
            lastMousePosition = current;
        }
    }
}
```

### 3. Заставка «Часы» (5.3) — ClockScreenWindow.xaml

**XAML** (используем Canvas для свободного перемещения):

```xml
<Window x:Class="LabWork24.ClockScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClockScreen" Height="450" Width="800"
        WindowStyle="None" WindowState="Maximized"
        Background="Black"
        KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove"
        Loaded="Window_Loaded">
    <Canvas x:Name="mainCanvas">
        <TextBlock x:Name="timeText" 
                   FontSize="80" 
                   FontWeight="Bold" 
                   Foreground="Lime"
                   Text="00:00:00"/>
    </Canvas>
</Window>
```

**Code-behind** (`ClockScreenWindow.xaml.cs`):

```csharp
using System;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;
using System.Windows.Media;
using System.Windows.Threading;

namespace LabWork24
{
    public partial class ClockScreenWindow : Window
    {
        private int dx = 8;
        private int dy = 6;
        private Point lastMousePosition;
        private DispatcherTimer timer;

        public ClockScreenWindow()
        {
            InitializeComponent();
        }

        private void Window_Loaded(object sender, RoutedEventArgs e)
        {
            timeText.Text = DateTime.Now.ToString("HH:mm:ss");

            // Центрируем программно
            Canvas.SetLeft(timeText, (mainCanvas.ActualWidth - timeText.ActualWidth) / 2);
            Canvas.SetTop(timeText, (mainCanvas.ActualHeight - timeText.ActualHeight) / 2);

            timer = new DispatcherTimer();
            timer.Interval = TimeSpan.FromSeconds(1);
            timer.Tick += Timer_Tick;
            timer.Start();

            lastMousePosition = Mouse.GetPosition(this);
        }

        private void Timer_Tick(object sender, EventArgs e)
        {
            timeText.Text = DateTime.Now.ToString("HH:mm:ss");

            double left = Canvas.GetLeft(timeText) + dx;
            double top = Canvas.GetTop(timeText) + dy;

            // Отражение от краёв (как бильярдный шар)
            if (left < 0 || left + timeText.ActualWidth > mainCanvas.ActualWidth)
                dx = -dx;
            if (top < 0 || top + timeText.ActualHeight > mainCanvas.ActualHeight)
                dy = -dy;

            Canvas.SetLeft(timeText, left);
            Canvas.SetTop(timeText, top);
        }

        private void Window_KeyDown(object sender, KeyEventArgs e)
        {
            this.Close();
        }

        private void Window_MouseMove(object sender, MouseEventArgs e)
        {
            Point current = Mouse.GetPosition(this);
            if (Math.Abs(current.X - lastMousePosition.X) > 3 ||
                Math.Abs(current.Y - lastMousePosition.Y) > 3)
            {
                this.Close();
            }
            lastMousePosition = current;
        }
    }
}
```

### Как запускать каждую заставку

Откройте файл **`App.xaml.cs`** и замените метод `OnStartup` на один из вариантов:

```csharp
// === Для пустого экрана ===
protected override void OnStartup(StartupEventArgs e)
{
    base.OnStartup(e);
    new EmptyScreenWindow().Show();
}

// === Для фотографий ===
// new PhotoScreenWindow().Show();

// === Для часов ===
// new ClockScreenWindow().Show();
```

Сохраните, нажмите **F5** — получите полностью рабочую заставку точно по заданию лабораторной.

