const int ledPin = 13;

unsigned long startTime = 0;
bool ledOn = true;

void setup() {
  pinMode(ledPin, OUTPUT);
  Serial.begin(9600);
  startTime = millis();
  digitalWrite(ledPin, HIGH);
}

void loop() {
  unsigned long current = millis();

  // Выключаем LED через 5 секунд
  if (ledOn && current - startTime >= 5000) {
    digitalWrite(ledPin, LOW);
    ledOn = false;
  }

  // Каждую секунду печатаем Hello World
  static unsigned long lastPrint = 0;
  if (current - lastPrint >= 1000) {
    Serial.println("Hello World");
    lastPrint = current;
  }
}


