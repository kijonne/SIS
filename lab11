unsigned long startTime = 0;

void setup() {
  Serial.begin(9600);
  startTime = millis();
  Serial.println("Схема запущена!");
}

void loop() {
  unsigned long seconds = (millis() - startTime) / 1000;
  Serial.print("Прошло секунд: ");
  Serial.println(seconds);
  
  delay(1000);  // только здесь delay — для вывода раз в секунду
}


