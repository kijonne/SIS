const int ledPin = 9;

unsigned long phaseStart = 0;
int phase = 0;           // 0, 1, 2
int period = 1000;       // стартовый период в мс

void setup() {
  pinMode(ledPin, OUTPUT);
  phaseStart = millis();
}

void loop() {
  unsigned long current = millis();

  // Меняем фазу каждые 5 секунд
  if (current - phaseStart >= 5000) {
    phase = (phase + 1) % 3;
    phaseStart = current;
    
    if (phase == 0) period = 1000;      // 0-5с
    else if (phase == 1) period = 750;  // 6-10с
    else period = 500;                  // 11-15с
  }

  // Мигание с текущим периодом
  static unsigned long lastToggle = 0;
  if (current - lastToggle >= period / 2) {  // полупериод
    lastToggle = current;
    digitalWrite(ledPin, !digitalRead(ledPin));
  }
}
